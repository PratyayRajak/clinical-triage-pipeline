# LiteLLM
# Groq is the recommended primary model for the demo. Gemini is configured as a
# practical fallback in the code when GOOGLE_API_KEY is present.
LITELLM_MODEL=groq/llama-3.1-8b-instant

# API keys
# Fill the key for your primary model. Optional fallback keys can also be set.
OPENAI_API_KEY=
GOOGLE_API_KEY=your_optional_google_fallback_key_here
GROQ_API_KEY=your_groq_key_here
MISTRAL_API_KEY=
COHERE_API_KEY=
ANTHROPIC_API_KEY=

# MLflow
# Local file tracking is easiest for demos. Use http://localhost:5000 only when
# you have an MLflow server running.
MLFLOW_TRACKING_URI=file:./mlruns
MLFLOW_EXPERIMENT_NAME=clinical-triage-pipeline

# Paths
DATA_RAW_PATH=data/sample/mtsamples.csv
DELTA_BASE_PATH=data/delta
CHROMA_PERSIST_DIR=data/chroma_db
USE_VECTOR_RETRIEVAL=false

# API
API_HOST=0.0.0.0
API_PORT=8000
WARMUP_ON_STARTUP=false

# Risk thresholds
HIGH_RISK_THRESHOLD=0.7
MEDIUM_RISK_THRESHOLD=0.4

# Drift monitoring
DRIFT_ALERT_THRESHOLD=0.05
MONITOR_INTERVAL_HOURS=6
